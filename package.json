{
  "name": "playwright-bdd-framework",
  "version": "1.0.0",
  "scripts": {
    "start": "ts-node ./src/utils/server.ts",
    "run": "npx bddgen && tsx src/utils/test-runner.ts",
    "run:ui": "npx bddgen && tsx src/utils/test-runner.ts --ui",
    "run:headed": "npx bddgen && tsx src/utils/test-runner.ts --headed",
    "test": "npx bddgen && npm run run:headed",
    "watch:bdd": "nodemon -w ./features -e feature,js,ts --exec \"npx bddgen\"",
    "watch:pw": "playwright test --ui",
    "watch": "run-p watch:*",
    "fmt": "prettier -w . --ignore-pattern .prettierignore",
    "lint:gherkin": "gherkin-lint \"features\"",
    "lint": "eslint . --fix --max-warnings 0 --no-cache",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "logs:clean": "rimraf artifacts/logs",
    "report:generate:allure": "npx cross-env ALLURE_NO_ANALYTICS=1 allure generate --single-file artifacts/reports/allure-results -o artifacts/reports/allure-report --clean",
    "report:open:allure": "npm run report:generate:allure && npx cross-env ALLURE_NO_ANALYTICS=1 allure open artifacts/reports/allure-report",
    "report:open:monocart": "npx monocart show-report artifacts/reports/monocart-report/",
    "report:open:html": "npx playwright show-report artifacts/reports/html-reports",
    "report:open:tta": "npx http-server artifacts/reports/tta-report -c-1 -a localhost -o index.html",
    "prepare": "husky"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@apollo/client": "^3.8.0",
    "@eslint/js": "^9.36.0",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^6.4.0",
    "@faker-js/faker": "^9.7.0",
    "@slack/webhook": "^7.0.6",
    "@types/adm-zip": "^0.5.7",
    "@types/argparse": "^2.0.17",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.14.191",
    "@types/node": "^20.14.15",
    "@types/nodemailer": "^7.0.4",
    "adm-zip": "^0.5.16",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.2.1",
    "chance": "^1.1.12",
    "cross-env": "^7.0.3",
    "cross-fetch": "^3.1.5",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cucumber": "^2.0.0",
    "eslint-plugin-jsonc": "^2.20.0",
    "eslint-plugin-playwright": "^2.0.0",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.3",
    "gherkin-lint": "^4.2.4",
    "globals": "^15.12.0",
    "graphql": "^16.7.1",
    "http-server": "14.1.1",
    "husky": "^9.1.7",
    "kolorist": "^1.8.0",
    "lint-staged": "^15.5.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "monocart-reporter": "^2.9.18",
    "nodemailer": "^8.0.11",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "playwright-bdd": "^9.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-gherkin": "^4.0.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.8.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "tsc --noEmit",
      "prettier -w . --ignore-pattern .prettierignore",
      "eslint . --fix --max-warnings 0 --no-cache",
      "npx gherkin-lint ./features"
    ]
  }
}
